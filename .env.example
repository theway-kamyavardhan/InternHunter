# ==========================================
# Intern-Hunter-AI Environment Configuration
# ==========================================

# 1. LLM API Keys (Groq is default for speed, Gemini as fallback)
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIzaSy..."

# 2. Email Sending (SendGrid primary, Gmail SMTP fallback)
SENDGRID_API_KEY="SG...."
# Or if using Gmail App Password:
GMAIL_ADDRESS="your.email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# 3. IMAP (For Reply Intelligence - Reading incoming emails)
IMAP_SERVER="imap.gmail.com"
IMAP_PORT=993
IMAP_USERNAME="your.email@gmail.com"
IMAP_PASSWORD="xxxx xxxx xxxx xxxx"

# 4. Telegram Bot (For Human-In-The-Loop Guidance)
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNO..."
TELEGRAM_CHAT_ID="987654321"

# 5. Obsidian Path (Absolute path to your vault, defaults to local folder)
OBSIDIAN_VAULT_PATH="./obsidian_template"
